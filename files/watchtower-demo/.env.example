# ----- Watchtower behaviour -----

# How often Watchtower polls the registry (in seconds).
# Default in docker-compose.yml is 30. Production usage is typically 86400 (24h).
# WATCHTOWER_POLL_INTERVAL=30

# Only watch containers with com.centurylinklabs.watchtower.enable=true.
# WATCHTOWER_LABEL_ENABLE=true

# Remove the old image after a successful update so disk does not grow.
# WATCHTOWER_CLEANUP=true


# ----- Demo ports (used by docker-compose.yml) -----

# APP_PORT=8090

# Host port for the local Docker registry that the demo pushes to.
# REGISTRY_PORT=5000
